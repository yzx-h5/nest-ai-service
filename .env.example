# DeepSeek LLM
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
OPENAI_TEMPERATURE=0.7

# Knowledge base（knowledge.service initialize）
# 本地开发需先启动 Qdrant: pnpm run qdrant:up  （需 Docker Desktop 运行中）
# docker compose 部署 app 时改为: QDRANT_URL=http://qdrant:6333

# Embedding（Moark OpenAI 兼容 API；base 填到 /v1，客户端会自动请求 /embeddings）
OPENAI_EMBEDDING_MODEL=bge-m3
EMBEDDING_API_KEY=HBBDJGFHMV406ZE36RZ6ZC5TKTUATSLGRHAHEQ1E
EMBEDDING_BASE_URL=https://api.moark.com/v1
EMBEDDING_FAILOVER_ENABLED=true
# Moark API 单次 input 数组上限约 25（LangChain 默认 512 会 400）
EMBEDDING_BATCH_SIZE=25

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_base
# QDRANT_API_KEY=

# Chunking & retrieval
KNOWLEDGE_CHUNK_SIZE=1000
KNOWLEDGE_CHUNK_OVERLAP=200
KNOWLEDGE_RETRIEVAL_K=4

# Server
PORT=3000

# Logging
LOG_LEVEL=debug

# Monitoring (Grafana default credentials in docker-compose.yml)
# Grafana: http://localhost:3001  (admin / admin)
# Prometheus: http://localhost:9090
