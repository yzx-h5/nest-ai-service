# DeepSeek LLM
OPENAI_API_KEY=xxx
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
OPENAI_TEMPERATURE=0.7

# Embedding（Moark OpenAI 兼容 API；base 填到 /v1，客户端会自动请求 /embeddings）
OPENAI_EMBEDDING_MODEL=bge-m3
EMBEDDING_API_KEY=xxx
EMBEDDING_BASE_URL=https://api.moark.com/v1
EMBEDDING_FAILOVER_ENABLED=true
# Moark API 单次 input 数组上限约 25（LangChain 默认 512 会 400）
EMBEDDING_BATCH_SIZE=25

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_base
# QDRANT_API_KEY=

# Chunking & retrieval
KNOWLEDGE_CHUNK_SIZE=1500
KNOWLEDGE_CHUNK_OVERLAP=300
# 最终返回给模型的片段数（MMR 选出）
KNOWLEDGE_RETRIEVAL_K=8
# 先从向量库多取候选，再按关键词加权重排
KNOWLEDGE_FETCH_K=24
# 网页导入默认禁止访问 localhost 和私网地址；仅在受控内网按需开启
KNOWLEDGE_WEB_ALLOW_PRIVATE_NETWORK=false

# Server
PORT=3000

# Logging
LOG_LEVEL=debug
# 请求体最大大小，上传文件仍由 Multer 的 20MB 限制控制
BODY_SIZE_LIMIT=1mb
# 部署在受信任反向代理后才设为 true，否则保留 false 防止伪造客户端 IP
TRUST_PROXY=false
# 生产环境默认关闭；仅在受保护的内网按需启用
SWAGGER_ENABLED=true

# Monitoring - Grafana（生产环境请使用密钥管理系统注入强密码）
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-grafana-password

# Security - CORS
# CORS_ENABLED=false 可完全关闭跨域；CORS_ORIGIN 支持 * 或逗号分隔的来源白名单
# 生产环境必须使用明确来源白名单，例如 https://admin.example.com
CORS_ENABLED=false
CORS_ORIGIN=

# Security - API Key 鉴权
# 未显式设置 API_KEY_AUTH_ENABLED 时，配置了 API_KEYS 即自动开启鉴权
# 请求需携带请求头 x-api-key；多个 Key 用逗号分隔以便分配/轮换
API_KEY_AUTH_ENABLED=true
API_KEYS=replace-with-a-strong-key

# Security - 限流（每个 IP 在 RATE_LIMIT_TTL 秒内最多 RATE_LIMIT_MAX 次请求）
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
